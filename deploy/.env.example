# Ananta — Environment Configuration
# Copy this to .env and fill in real values:
#   cp deploy/.env.example deploy/.env

# ─── Domain ──────────────────────────────────────────────
DOMAIN=your-domain.com
# Use "localhost" for local testing

# ─── PostgreSQL ──────────────────────────────────────────
POSTGRES_DB=ananta
POSTGRES_USER=ananta
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ─── MongoDB ─────────────────────────────────────────────
MONGO_USER=ananta
MONGO_PASSWORD=CHANGE_ME_strong_password_here

# ─── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_password_here

# ─── Keycloak ────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_strong_password_here
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_generate_a_uuid

# ─── Optional: AWS (for S3 document storage) ─────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# S3_BUCKET=ananta-documents
