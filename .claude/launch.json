{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "/opt/homebrew/bin/pnpm",
      "runtimeArgs": ["--filter", "@ananta/web", "dev"],
      "port": 3000
    },
    {
      "name": "patient-service",
      "runtimeExecutable": "/opt/homebrew/bin/pnpm",
      "runtimeArgs": ["--filter", "@ananta/patient-service", "dev"],
      "port": 3001
    },
    {
      "name": "doctor-service",
      "runtimeExecutable": "/opt/homebrew/bin/pnpm",
      "runtimeArgs": ["--filter", "@ananta/doctor-service", "dev"],
      "port": 3002
    },
    {
      "name": "emergency-service",
      "runtimeExecutable": "/opt/homebrew/bin/pnpm",
      "runtimeArgs": ["--filter", "@ananta/emergency-service", "dev"],
      "port": 3003
    },
    {
      "name": "auth-service",
      "runtimeExecutable": "/opt/homebrew/bin/pnpm",
      "runtimeArgs": ["--filter", "@ananta/auth-service", "dev"],
      "port": 3004
    },
    {
      "name": "ai-service",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["app.main:app", "--reload", "--host", "0.0.0.0", "--port", "3005", "--app-dir", "app/services/ai-service"],
      "port": 3005
    },
    {
      "name": "mobile",
      "runtimeExecutable": "/opt/homebrew/bin/pnpm",
      "runtimeArgs": ["--filter", "@ananta/mobile", "dev"],
      "port": 8081
    }
  ]
}
